<div class="container p-4">
  <div class="row">
    <div class="col-md-4 mx-auto">
      <form class="card card-body bg-dark text-white p-5" action="/signup" method="POST">
        <h3 class="text-center fw-bold mb-4">Registese</h3>

        <label for="fullname">Escriba su nombre completo:</label>
        <input type="type" name="fullname" placeholder="" class="form-control mb-3" autofocus />

        <label for="username">Escriba su correo electrónico:</label>
        <input type="email" name="email" placeholder="" class="form-control mb-3" />

        <label for="password">Escriba su contraseña:</label>
        <input type="password" name="password1" placeholder="" class="form-control mb-3" />

        {{!-- Confirm your password --}}
        <label for="password">Confirmar la contraseña:</label>
        <input type="password" name="password2" placeholder="" class="form-control mb-3" />

        <button class="btn btn-success btn-block">
          Registrarse
        </button>
    </div>
    </form>

    {{! Link }}
    {{!-- <p class="fs-5 text-center text-white mt-3">Do you already have an account?
      <a href="/signin" class="text-info">Signin</a>
    </p> --}}
  </div>
</div>